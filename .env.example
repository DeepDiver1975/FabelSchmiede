# LLM provider configuration for the GM engine.
# Copy to .env and fill in. .env is git-ignored — never commit it.
#
# Set LLM_PROVIDER to anthropic|bedrock|nim to pick a provider explicitly.
# If left unset, the server auto-detects: ANTHROPIC_API_KEY takes precedence,
# otherwise it falls back to AWS Bedrock using AWS_REGION below. NIM is never
# auto-selected — it requires LLM_PROVIDER=nim.
# LLM_PROVIDER=
ANTHROPIC_API_KEY=

# AWS Bedrock fallback (used only if ANTHROPIC_API_KEY is unset).
# Credentials resolve via the standard AWS chain (env vars, shared profile, or IAM role).
AWS_REGION=eu-central-1
# Option A: static keys (simplest for a hobby laptop)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Option B: leave the keys blank and set AWS_PROFILE instead
# AWS_PROFILE=default

# NVIDIA NIM (free tier, build.nvidia.com API Catalog).
# Requires LLM_PROVIDER=nim above to be selected explicitly.
NVIDIA_API_KEY=
NIM_MODEL=meta/llama-3.3-70b-instruct

BACKEND_PORT=8787
